APP_ENV=dev

# JWT secret (change in production)
JWT_SECRET_KEY=synapse-dev-secret-change-me

# Agent HMAC master key: 32 raw bytes or 64 hex chars
# Generate with: openssl rand -hex 32
SYNAPSE_AGENT_SECRET_KEY=

# Database overrides (optional, defaults in config.dev.yaml)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=synapse

# Redis overrides (optional)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Postgres (pgvector) overrides (optional; leave PG_HOST empty to disable vector indexing)
# PG_HOST=127.0.0.1
# PG_PORT=15432
# PG_USERNAME=postgres
# PG_PASSWORD=
# PG_DATABASE=synapse
# PG_SSL_MODE=disable

# Azure embedding API key (override for generation when not writing yaml in prod)
# AZURE_EMBEDDING_API_KEY=
